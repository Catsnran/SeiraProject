<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="760" prefWidth="1200" styleClass="main-root" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.seira.controllers.MainController">

    <!-- Sidebar -->
    <VBox fx:id="sidebar" prefWidth="220" styleClass="sidebar">
        <padding><Insets bottom="24" left="24" right="24" top="28" /></padding>

        <!-- Brand -->
        <VBox spacing="2" styleClass="sidebar-brand">
            <Label styleClass="sidebar-logo" text="Seira" />
            <Label styleClass="sidebar-tagline" text="FISCAL CURATOR" />
        </VBox>

        <Region prefHeight="32" />

        <!-- Nav items -->
        <VBox fx:id="navContainer" spacing="4">
            <Button fx:id="navDashboard" maxWidth="Infinity" onAction="#navDashboard" styleClass="nav-item" text="Dashboard" userData="dashboard">
                <graphic><Label styleClass="nav-icon" text="⊞" /></graphic>
            </Button>
            <Button fx:id="navTransactions" maxWidth="Infinity" onAction="#navTransactions" styleClass="nav-item" text="Transactions" userData="transactions">
                <graphic><Label styleClass="nav-icon" text="⇄" /></graphic>
            </Button>
            <Button fx:id="navBudget" maxWidth="Infinity" onAction="#navBudget" styleClass="nav-item" text="Budget" userData="budget">
                <graphic><Label styleClass="nav-icon" text="▤" /></graphic>
            </Button>
            <Button fx:id="navReports" maxWidth="Infinity" onAction="#navReports" styleClass="nav-item" text="Reports" userData="reports">
                <graphic><Label styleClass="nav-icon" text="↗" /></graphic>
            </Button>
            <Button fx:id="navAccounts" maxWidth="Infinity" onAction="#navAccounts" styleClass="nav-item" text="Accounts" userData="accounts">
                <graphic><Label styleClass="nav-icon" text="⌂" /></graphic>
            </Button>
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <!-- Add Transaction -->
        <Button maxWidth="Infinity" onAction="#openAddTransaction" styleClass="btn-add-transaction" text="+ Add Transaction" />

        <Region prefHeight="16" />

        <!-- Bottom nav -->
        <VBox spacing="4">
            <Button maxWidth="Infinity" onAction="#openSettings" styleClass="nav-item-bottom" text="⚙  Settings" />
            <Button maxWidth="Infinity" onAction="#openSupport" styleClass="nav-item-bottom" text="?  Support" />
         <Button layoutX="10.0" layoutY="39.0" maxWidth="Infinity" onAction="#navLogout" styleClass="nav-item-bottom" text="Logout" />
        </VBox>
    </VBox>

    <!-- Content Area -->
    <VBox fx:id="contentArea" styleClass="content-area" HBox.hgrow="ALWAYS">
        <!-- Top bar -->
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets bottom="14" left="32" right="32" top="14" /></padding>
            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="380" promptText="Search transactions, tags, or merchants..." styleClass="search-field" HBox.hgrow="ALWAYS" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="12">
                <Label styleClass="top-icon" text="🔔" />
                <Label fx:id="userInitial" styleClass="user-avatar" />
            </HBox>
        </HBox>

        <!-- Dynamic content -->
        <StackPane fx:id="pageContainer" styleClass="page-container" VBox.vgrow="ALWAYS" />
    </VBox>
</HBox>
