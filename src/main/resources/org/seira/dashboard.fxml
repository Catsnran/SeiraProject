<?import javafx.scene.text.Font?>


<VBox alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.seira.controller.ClickyController">
   <children>
      <Label text="TODO: Dashboard">
         <font>
            <Font size="36.0" />
         </font>
      </Label>
      <Label text="In the meantime, have a button!">
         <VBox.margin>
            <Insets bottom="5.0" top="5.0" />
         </VBox.margin>
      </Label>
      <Button mnemonicParsing="false" onAction="#clicky" text="Click me!" />
   </children>
</VBox>
