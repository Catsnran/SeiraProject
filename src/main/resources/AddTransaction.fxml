<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seira.controllers.AddTransactionController"
      styleClass="page-hbox" spacing="24">
    <padding><Insets top="32" left="32" bottom="32" right="32"/></padding>

    <!-- Left: Amount + numpad -->
    <VBox spacing="16" prefWidth="380">
        <VBox spacing="4">
            <Label text="Tambah Transaksi" styleClass="page-title"/>
            <Label text="Catat entri baru dalam riwayat fiskalmu." styleClass="page-subtitle"/>
        </VBox>

        <!-- Amount display -->
        <VBox styleClass="amount-display-box" alignment="CENTER" prefHeight="110">
            <padding><Insets top="20" left="24" bottom="20" right="24"/></padding>
            <Label text="TOTAL JUMLAH" styleClass="mini-label" style="-fx-text-fill: rgba(255,255,255,0.6);"/>
            <Label fx:id="amountDisplay" text="Rp 0" styleClass="amount-display"/>
        </VBox>

        <!-- Numpad -->
        <GridPane styleClass="numpad" hgap="8" vgap="8">
            <Button text="1" styleClass="numpad-btn" GridPane.columnIndex="0" GridPane.rowIndex="0" onAction="#pressKey1" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="2" styleClass="numpad-btn" GridPane.columnIndex="1" GridPane.rowIndex="0" onAction="#pressKey2" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="3" styleClass="numpad-btn" GridPane.columnIndex="2" GridPane.rowIndex="0" onAction="#pressKey3" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="4" styleClass="numpad-btn" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#pressKey4" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="5" styleClass="numpad-btn" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#pressKey5" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="6" styleClass="numpad-btn" GridPane.columnIndex="2" GridPane.rowIndex="1" onAction="#pressKey6" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="7" styleClass="numpad-btn" GridPane.columnIndex="0" GridPane.rowIndex="2" onAction="#pressKey7" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="8" styleClass="numpad-btn" GridPane.columnIndex="1" GridPane.rowIndex="2" onAction="#pressKey8" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="9" styleClass="numpad-btn" GridPane.columnIndex="2" GridPane.rowIndex="2" onAction="#pressKey9" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="." styleClass="numpad-btn" GridPane.columnIndex="0" GridPane.rowIndex="3" onAction="#pressDot" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="0" styleClass="numpad-btn" GridPane.columnIndex="1" GridPane.rowIndex="3" onAction="#pressKey0" maxWidth="Infinity" maxHeight="Infinity"/>
            <Button text="⌫" styleClass="numpad-btn-del" GridPane.columnIndex="2" GridPane.rowIndex="3" onAction="#pressBackspace" maxWidth="Infinity" maxHeight="Infinity"/>
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints prefHeight="52" vgrow="ALWAYS"/>
                <RowConstraints prefHeight="52" vgrow="ALWAYS"/>
                <RowConstraints prefHeight="52" vgrow="ALWAYS"/>
                <RowConstraints prefHeight="52" vgrow="ALWAYS"/>
            </rowConstraints>
        </GridPane>

        <!-- Decorative hint -->
        <VBox styleClass="card-muted" alignment="CENTER" prefHeight="56">
            <Label text="Catat setiap pengeluaran untuk menjaga&#10;kesehatan fiskalmu dengan presisi." styleClass="mini-label" textAlignment="CENTER" wrapText="true"/>
        </VBox>
    </VBox>

    <!-- Right: Form -->
    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <VBox styleClass="card" spacing="20" VBox.vgrow="ALWAYS">
            <padding><Insets top="24" left="24" bottom="24" right="24"/></padding>

            <!-- Type tabs — using Buttons, not ToggleButtons -->
            <HBox spacing="0" styleClass="type-tabs">
                <Button fx:id="tabExpense" text="Pengeluaran" styleClass="type-tab-active" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#selectExpense"/>
                <Button fx:id="tabIncome" text="Pemasukan" styleClass="type-tab" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#selectIncome"/>
                <Button fx:id="tabTransfer" text="Transfer" styleClass="type-tab" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#selectTransfer"/>
            </HBox>

            <!-- Account -->
            <VBox spacing="6">
                <Label text="AKUN" styleClass="field-label"/>
                <ComboBox fx:id="accountCombo" styleClass="combo-field" maxWidth="Infinity"/>
            </VBox>

            <!-- Category row (hidden for Transfer) -->
            <VBox fx:id="categoryRow" spacing="6">
                <Label text="KATEGORI" styleClass="field-label"/>
                <ComboBox fx:id="categoryCombo" styleClass="combo-field" maxWidth="Infinity"/>
            </VBox>

            <!-- Transfer-to row (shown only for Transfer) -->
            <VBox fx:id="transferToRow" spacing="6" visible="false" managed="false">
                <Label text="KE AKUN (TUJUAN)" styleClass="field-label"/>
                <ComboBox fx:id="transferToCombo" styleClass="combo-field" maxWidth="Infinity"/>
            </VBox>

            <!-- Date + Reference -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="TANGGAL" styleClass="field-label"/>
                    <DatePicker fx:id="datePicker" styleClass="date-field" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="REFERENSI (OPSIONAL)" styleClass="field-label"/>
                    <TextField fx:id="referenceField" promptText="#REF-" styleClass="login-field"/>
                </VBox>
            </HBox>

            <!-- Notes -->
            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Label text="DESKRIPSI &amp; CATATAN" styleClass="field-label"/>
                <TextArea fx:id="notesArea" promptText="Masukkan detail transaksi..."
                          styleClass="notes-area" VBox.vgrow="ALWAYS" wrapText="true" prefHeight="90"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12">
                <Button text="BATAL" styleClass="btn-outline" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleCancel"/>
                <Button text="SIMPAN TRANSAKSI" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleSave"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
