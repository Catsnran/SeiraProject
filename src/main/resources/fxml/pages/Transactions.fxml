<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox styleClass="page-hbox" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seira.controllers.TransactionsController">

    <!-- Main ledger -->
    <VBox spacing="20" HBox.hgrow="ALWAYS">
        <padding><Insets bottom="32" left="32" right="16" top="32" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Transaksi" />
                <Label styleClass="page-subtitle" text="Mendokumentasikan perjalananmu menuju kejernihan fiskal." />
            </VBox>
            <HBox alignment="CENTER" spacing="8">
                <Button fx:id="btnFilterAll" onAction="#filterAll" styleClass="filter-btn-active" text="Semua" />
                <Button fx:id="btnFilterExpenses" onAction="#filterExpenses" styleClass="filter-btn" text="Pengeluaran" />
                <Button fx:id="btnFilterIncome" onAction="#filterIncome" styleClass="filter-btn" text="Pemasukan" />
                <Button onAction="#showDatePicker" styleClass="btn-outline-small" text="📅 Rentang Tanggal" />
            </HBox>
        </HBox>

        <!-- Ledger table -->
        <VBox spacing="0" styleClass="card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" styleClass="ledger-header">
                <padding><Insets bottom="14" left="20" right="20" top="14" /></padding>
                <Label prefHeight="17.0" prefWidth="536.0" styleClass="card-title" text="The Ledger" HBox.hgrow="ALWAYS">
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets></Label>
                <Button onAction="#exportCsv" styleClass="btn-ghost" text="⬇ Export CSV" />
            </HBox>

            <!-- Column headers -->
            <HBox prefHeight="37.0" prefWidth="645.0" styleClass="table-header">
                <padding><Insets bottom="10" left="20" right="20" top="10" /></padding>
                <Label prefHeight="17.0" prefWidth="145.0" styleClass="col-header" text="TANGGAL" />
                <Label prefHeight="17.0" prefWidth="259.0" styleClass="col-header" text="DESKRIPSI" HBox.hgrow="ALWAYS" />
                <Label prefHeight="17.0" prefWidth="200.0" styleClass="col-header" text="KATEGORI" />
                <Label prefHeight="17.0" prefWidth="77.0" styleClass="col-header" text="JUMLAH" />
                <Label prefWidth="70" text="" />
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="400" styleClass="table-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="transactionList" styleClass="transaction-list" />
            </ScrollPane>

            <HBox alignment="CENTER" styleClass="show-more-row">
                <padding><Insets bottom="14" top="14" /></padding>
                <Button fx:id="showMoreBtn" onAction="#showMore" styleClass="btn-ghost" text="Tampilkan Lebih Banyak" visible="false" />
            </HBox>
        </VBox>
    </VBox>

    <!-- Wealth Narrative sidebar -->
    <VBox prefWidth="240" spacing="0">
        <padding><Insets bottom="32" left="0" right="24" top="32" /></padding>
        <VBox prefHeight="539.0" prefWidth="140.0" spacing="16" styleClass="card-accent" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="24" left="20" right="20" top="24" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label styleClass="accent-icon" text="✦" />
                <Label styleClass="accent-icon-sm" text="✦" />
            </HBox>
            <Label styleClass="narrative-title" text="Wealth Narrative" />
            <Label fx:id="narrativeText" styleClass="narrative-body" text="Mulai tambahkan transaksi untuk melihat narasi keuanganmu." wrapText="true" />
            <Region VBox.vgrow="ALWAYS" />
            <HBox>
                <Label styleClass="curated-label" text="CURATED INSIGHT" HBox.hgrow="ALWAYS" />
                <Label styleClass="link-accent" text="Deep Dive" />
            </HBox>
        </VBox>
    </VBox>
</HBox>
