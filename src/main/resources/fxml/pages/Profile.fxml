<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.seira.controllers.ProfileControllers"
            fitToWidth="true" styleClass="page-scroll" hbarPolicy="NEVER">

    <VBox styleClass="page-content" spacing="24">
        <padding><Insets top="32" left="32" bottom="32" right="32"/></padding>

        <!-- Back Button -->
        <HBox alignment="CENTER_LEFT">
            <Button fx:id="btnBack" text="← Kembali ke Dasbor" styleClass="btn-outline" onAction="#goBackToDashboard"/>
        </HBox>

        <!-- Header -->
        <VBox spacing="4" alignment="CENTER">
            <Label text="PROFIL PENGGUNA" styleClass="page-eyebrow"/>
            <Label text="Informasi Akun" styleClass="page-title"/>
            <Label text="Kelola data pribadi dan foto profil Anda" styleClass="page-subtitle"/>
        </VBox>

        <!-- Profile Card -->
        <HBox alignment="CENTER">
            <VBox styleClass="card" prefWidth="520" spacing="0">
                <padding><Insets top="0" left="0" bottom="0" right="0"/></padding>

                <!-- Profile Photo Section -->
                <VBox alignment="CENTER" spacing="12" styleClass="profile-photo-section">
                    <padding><Insets top="32" left="32" bottom="24" right="32"/></padding>

                    <StackPane fx:id="photoContainer" styleClass="profile-photo-container">
                        <!-- Default avatar initial -->
                        <Label fx:id="avatarInitial" styleClass="profile-avatar-initial"/>
                        <!-- Actual image (hidden by default) -->
                        <ImageView fx:id="profileImageView" fitWidth="100" fitHeight="100" preserveRatio="false" styleClass="profile-image-view"/>
                    </StackPane>

                    <Button fx:id="btnChangePhoto" text="Ubah Foto" styleClass="btn-ghost" onAction="#changePhoto" visible="false" managed="false"/>
                    <Label fx:id="photoHint" text="" styleClass="mini-label" visible="false" managed="false"/>
                </VBox>

                <!-- Divider -->
                <Region styleClass="profile-divider" prefHeight="1" maxWidth="1.7976931348623157E308"/>

                <!-- Form Fields -->
                <VBox spacing="20" styleClass="profile-form-section">
                    <padding><Insets top="24" left="32" bottom="32" right="32"/></padding>

                    <!-- Username -->
                    <VBox spacing="6">
                        <Label text="USERNAME" styleClass="field-label"/>
                        <Label fx:id="usernameDisplay" styleClass="profile-field-display"/>
                        <TextField fx:id="usernameField" styleClass="login-field" visible="false" managed="false"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="6">
                        <Label text="EMAIL" styleClass="field-label"/>
                        <Label fx:id="emailDisplay" styleClass="profile-field-display"/>
                        <TextField fx:id="emailField" styleClass="login-field" visible="false" managed="false"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="6">
                        <Label text="PASSWORD" styleClass="field-label"/>
                        <Label fx:id="passwordDisplay" text="••••••••" styleClass="profile-field-display"/>
                        <PasswordField fx:id="passwordField" promptText="Kosongkan jika tidak ingin mengubah password" styleClass="login-field" visible="false" managed="false"/>
                        <Label fx:id="passwordHint" text="Kosongkan jika tidak ingin mengubah password" styleClass="mini-label" visible="false" managed="false"/>
                    </VBox>

                    <!-- Currency Preference -->
                    <VBox spacing="6">
                        <Label text="MATA UANG UTAMA" styleClass="field-label"/>
                        <Label fx:id="currencyDisplay" styleClass="profile-field-display"/>
                        <ComboBox fx:id="currencyCombo" styleClass="login-field" visible="false" managed="false"/>
                    </VBox>

                    <!-- Status Message -->
                    <Label fx:id="statusLabel" text="" visible="false" managed="false"/>

                    <!-- Edit Buttons -->
                    <HBox spacing="12" alignment="CENTER">
                        <Button fx:id="btnEditProfile" text="Edit Profil" styleClass="btn-primary" onAction="#toggleEditMode" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnCancel" text="Batal" styleClass="btn-outline" onAction="#cancelEdit" visible="false" managed="false"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
