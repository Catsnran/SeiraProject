<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.seira.controllers.AccountsControllers"
            fitToWidth="true" styleClass="page-scroll" hbarPolicy="NEVER">

    <VBox styleClass="page-content" spacing="24">
        <padding><Insets top="32" left="32" bottom="32" right="32"/></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Akun" styleClass="page-title"/>
                <Label text="Ringkasan editorial likuiditas yang kamu kurasi." styleClass="page-subtitle"/>
            </VBox>
            <Button text="＋ Tambah Akun Baru" styleClass="btn-primary" onAction="#openAddAccount"/>
        </HBox>

        <!-- Total Liquidity card -->
        <HBox spacing="20">
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="16">
                <padding><Insets top="24" left="24" bottom="24" right="24"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL LIKUIDITAS" styleClass="mini-label"/>
                        <Label fx:id="totalLiquidityLabel" text="Rp 0" styleClass="stat-large"/>
                        <Label fx:id="liquidityChangeLabel" text="" styleClass="stat-change-positive"/>
                    </VBox>
                    <Label text="🏛" style="-fx-font-size: 48; -fx-opacity: 0.25;"/>
                </HBox>
                <!-- Diversification bar -->
                <VBox spacing="8">
                    <Label text="DIVERSIFIKASI ASET" styleClass="mini-label"/>
                    <Pane fx:id="diversificationBar" prefHeight="10" prefWidth="400" maxWidth="Infinity" styleClass="diversification-bar-bg"/>
                </VBox>
            </VBox>
        </HBox>

        <!-- Account Cards -->
        <Label text="Sumber Dana" styleClass="card-title"/>
        <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" fitToHeight="true" prefHeight="220" styleClass="cards-scroll">
            <HBox fx:id="accountCardsBox" spacing="16" alignment="CENTER_LEFT">
                <padding><Insets top="4" bottom="12"/></padding>
            </HBox>
        </ScrollPane>

        <!-- Recent Allocations table -->
        <VBox styleClass="card" spacing="0">
            <HBox styleClass="ledger-header" alignment="CENTER_LEFT">
                <padding><Insets top="16" left="20" bottom="16" right="20"/></padding>
                <Label text="Alokasi Terkini" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Label text="Lihat Semua" styleClass="link-small"/>
            </HBox>

            <!-- Column headers -->
            <HBox styleClass="table-header">
                <padding><Insets top="10" left="20" bottom="10" right="20"/></padding>
                <Label text="" prefWidth="36"/>
                <Label text="AKUN" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                <Label text="STATUS" styleClass="col-header" prefWidth="100"/>
                <Label text="LAST SYNC" styleClass="col-header" prefWidth="130"/>
                <Label text="SALDO" styleClass="col-header" prefWidth="160"/>
            </HBox>

            <VBox fx:id="recentAllocationsList" styleClass="transaction-list"/>
        </VBox>
    </VBox>
</ScrollPane>
