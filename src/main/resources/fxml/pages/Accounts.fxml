<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.seira.controllers.AccountsControllers">

    <VBox spacing="24" styleClass="page-content">
        <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Akun" />
                <Label styleClass="page-subtitle" text="Ringkasan editorial likuiditas yang kamu kurasi." />
            </VBox>
            <Button onAction="#openAddAccount" styleClass="btn-primary" text="＋ Tambah Akun Baru" />
        </HBox>

        <!-- Total Liquidity card -->
        <HBox spacing="20">
            <VBox spacing="16" styleClass="card" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label styleClass="mini-label" text="TOTAL LIKUIDITAS" />
                        <Label fx:id="totalLiquidityLabel" styleClass="stat-large" text="Rp 0" />
                        <Label fx:id="liquidityChangeLabel" styleClass="stat-change-positive" text="" />
                    </VBox>
                    <Label style="-fx-font-size: 48; -fx-opacity: 0.25;" text="🏛" />
                </HBox>
                <!-- Diversification bar -->
                <VBox spacing="8">
                    <Label styleClass="mini-label" text="DIVERSIFIKASI ASET" />
                    <Pane fx:id="diversificationBar" maxWidth="Infinity" prefHeight="10" prefWidth="400" styleClass="diversification-bar-bg" />
                </VBox>
            </VBox>
        </HBox>

        <!-- Account Cards -->
        <Label styleClass="card-title" text="Sumber Dana">
            <VBox.margin><Insets top="8" /></VBox.margin>
        </Label>
        <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" prefHeight="220" styleClass="cards-scroll" vbarPolicy="NEVER">
            <HBox fx:id="accountCardsBox" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets bottom="12" top="4" /></padding>
            </HBox>
        </ScrollPane>

        <!-- Recent Allocations table -->
        <VBox spacing="0" styleClass="card">
            <HBox alignment="CENTER_LEFT" styleClass="ledger-header">
                <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
                <Label prefHeight="17.0" prefWidth="192.0" styleClass="card-title" text="Alokasi Terkini" HBox.hgrow="ALWAYS" />
                <Label styleClass="link-small" text="Lihat Semua" />
            </HBox>

            <!-- Column headers -->
            <HBox spacing="16" styleClass="table-header">
                <padding><Insets bottom="10" left="20" right="20" top="10" /></padding>
                <Label prefWidth="36" text="" />
                <Label styleClass="col-header" text="AKUN" HBox.hgrow="ALWAYS" />
                <Label prefWidth="100" styleClass="col-header" text="STATUS" />
                <!-- <Label text="SINKRONISASI TERAKHchIR" styleClass="col-header" prefWidth="130"/> -->
                <Label prefWidth="160" styleClass="col-header" text="SALDO" />
            </HBox>

            <VBox fx:id="recentAllocationsList" styleClass="transaction-list" />
        </VBox>
    </VBox>
</ScrollPane>
