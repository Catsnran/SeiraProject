<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.seira.controllers.ReportsControllers">

    <VBox spacing="24" styleClass="page-content">
        <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Laporan &amp; Analisis" />
                <Label styleClass="page-subtitle" text="Evaluasi keuangan jangka panjang dan analisis mendalam." />
            </VBox>
            <Button onAction="#exportCsv" styleClass="btn-outline" text="⬇ Export CSV" />
        </HBox>

        <!-- Top row: Net Worth Trend + Spending by Category -->
        <HBox spacing="20">
            <!-- Net Worth Trend chart -->
            <VBox spacing="16" styleClass="card" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="page-eyebrow" text="FISCAL TRAJECTORY" />
                        <Label styleClass="card-title" text="Tren Kekayaan Bersih" />
                    </VBox>
                    <HBox spacing="8">
                        <ToggleButton fx:id="btn12Months" onAction="#show12Months" selected="true" styleClass="filter-btn-active" text="12 Bulan" />
                        <ToggleButton fx:id="btnAllTime" onAction="#showAllTime" styleClass="filter-btn" text="Semua" />
                    </HBox>
                </HBox>
                <Pane fx:id="netWorthChartPane" prefHeight="240" styleClass="chart-pane" />
            </VBox>

            <!-- Spending by Category donut -->
            <VBox alignment="TOP_CENTER" prefWidth="280" spacing="16" styleClass="card">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
                <Label styleClass="card-title" text="Pengeluaran per Kategori" />
                <Pane fx:id="donutChartPane" maxWidth="200" prefHeight="200" prefWidth="200" />
                <Label fx:id="totalSpendingLabel" alignment="CENTER" styleClass="mini-label" text="Rp 0" />
                <VBox fx:id="donutLegend" spacing="10" />
            </VBox>
        </HBox>

        <!-- Monthly Comparative Breakdown -->
        <VBox spacing="0" styleClass="card">
            <HBox alignment="CENTER_LEFT" styleClass="ledger-header">
                <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
                <Label styleClass="card-title" text="Rincian Komparatif Bulanan" HBox.hgrow="ALWAYS" />
                <Button onAction="#exportCsv" styleClass="btn-ghost" text="⬇ Export CSV" />
            </HBox>

            <!-- Column headers -->
            <HBox styleClass="table-header">
                <padding><Insets bottom="10" left="20" right="20" top="10" /></padding>
                <Label prefWidth="120" styleClass="col-header" text="BULAN" />
                <Label prefWidth="140" styleClass="col-header" text="PEMASUKAN" />
                <Label prefWidth="140" styleClass="col-header" text="PENGELUARAN" />
                <Label prefHeight="17.0" prefWidth="124.0" styleClass="col-header" text="TINGKAT TABUNGAN" />
                <Label prefWidth="100" styleClass="col-header" text="STATUS" />
            </HBox>

            <VBox fx:id="monthlyBreakdownList" styleClass="transaction-list" />
        </VBox>
    </VBox>
</ScrollPane>
