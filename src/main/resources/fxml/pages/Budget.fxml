<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seira.controllers.BudgetControllers">

    <VBox spacing="24" styleClass="page-content">
        <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Budget Curator" />
                <Label styleClass="page-subtitle" text="Narasi pertumbuhan finansialmu melalui alokasi yang terencana." />
            </VBox>
            <Button onAction="#openPreviousCycles" styleClass="btn-outline" text="⏮ Siklus Sebelumnya">
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin></Button>
         <Button layoutX="344.0" layoutY="17.0" onAction="#openNextCycles" styleClass="btn-outline" text="Siklus Setelahnya ⏭" />
        </HBox>

        <!-- Main layout: Left panel + Right envelopes -->
        <HBox spacing="20">

            <!-- Left: Wealth Reservoir + Pace -->
            <VBox minWidth="260" prefWidth="280" spacing="16">

                <!-- Wealth Reservoir card -->
                <VBox spacing="16" styleClass="card">
                    <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-font-size: 28;" text="🐷" />
                        <VBox spacing="2">
                            <Label styleClass="reservoir-title" text="Wealth" />
                            <Label styleClass="reservoir-title" text="Reservoir" />
                        </VBox>
                    </HBox>
                    <VBox spacing="4">
                        <Label styleClass="mini-label" text="TOTAL ANGGARAN DIALOKASIKAN" />
                        <Label fx:id="totalAllocatedLabel" styleClass="stat-large" text="Rp 0" />
                    </VBox>
                    <VBox spacing="4">
                        <Label styleClass="mini-label" text="SISA UNTUK DIALOKASIKAN" />
                        <Label fx:id="remainingLabel" styleClass="stat-medium-accent" text="Rp 0" />
                    </VBox>
                </VBox>

                <!-- Monthly Pace card -->
                <VBox spacing="12" styleClass="card">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label styleClass="card-title" text="Laju Bulanan" HBox.hgrow="ALWAYS" />
                        <Label fx:id="paceStatusLabel" styleClass="badge-green" text="ON TRACK" />
                    </HBox>
                    <Pane fx:id="pacePaneContainer" prefHeight="60" prefWidth="200" />
                    <Label fx:id="paceDescLabel" styleClass="mini-label" text="Memuat data laju..." wrapText="true" />
                </VBox>

                <!-- Add new budget button -->
                <Button maxWidth="Infinity" onAction="#showAddBudgetDialog" styleClass="btn-primary" text="＋ Tambah Anggaran Baru" />
            </VBox>

            <!-- Right: Category Envelopes -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label styleClass="card-title" text="Category Envelopes" HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox fx:id="categoryEnvelopesList" spacing="12" />
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
