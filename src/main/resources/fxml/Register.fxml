<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seira.controllers.RegisterController"
      prefWidth="1100" prefHeight="700"
      styleClass="login-root">

    <!-- Left Branding Panel -->
    <VBox styleClass="login-left" HBox.hgrow="ALWAYS" prefWidth="520">
        <padding><Insets top="40" left="48" bottom="40" right="48"/></padding>

        <Label text="Seira" styleClass="brand-logo"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="16">
            <Label text="Start your" styleClass="login-headline"/>
            <Label text="fiscal" styleClass="login-headline"/>
            <Label text="journey." styleClass="login-headline-accent"/>
            <Label text="Create your personal ledger and take&#10;control of your financial narrative&#10;with Seira's intelligent tracking." styleClass="login-tagline" wrapText="true"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Label text="ESTABLISHED MMXXIV © SEIRA FISCAL" styleClass="login-footer"/>
    </VBox>

    <!-- Right Register Panel -->
    <VBox styleClass="login-right" prefWidth="520" HBox.hgrow="ALWAYS">
        <padding><Insets top="0" left="64" bottom="0" right="64"/></padding>
        <alignment>CENTER</alignment>

        <VBox spacing="8" maxWidth="360">
            <Label text="Create Account" styleClass="login-title"/>
            <Label text="Set up your Seira account to start curating your wealth." styleClass="login-subtitle" wrapText="true"/>
        </VBox>

        <Region prefHeight="32"/>

        <VBox spacing="16" maxWidth="360">
            <VBox spacing="6">
                <Label text="FULL NAME" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Your name" styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="EMAIL ADDRESS" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="curator@seira.com" styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Min. 6 characters" styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password" styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>
            <Label fx:id="successLabel" styleClass="success-label" visible="false" wrapText="true"/>

            <Region prefHeight="4"/>

            <Button text="Create Account" styleClass="btn-primary-full" maxWidth="Infinity" onAction="#handleRegister"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Already have an account?" styleClass="login-subtitle"/>
                <Label text="Log in" styleClass="link-label" onMouseClicked="#goToLogin"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
