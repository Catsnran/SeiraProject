<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1100" styleClass="login-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.seira.controllers.RegisterControllers">
   <StackPane prefWidth="597.0" styleClass="login-left" HBox.hgrow="ALWAYS">
         <ImageView fx:id="logo" fitHeight="400.0" fitWidth="360.0" pickOnBounds="false" preserveRatio="true">
            <image>
               <Image url="@../images/SeiraEnblem.png" />
            </image>
             <StackPane.alignment>BOTTOM_RIGHT</StackPane.alignment>
          <StackPane.margin>
              <Insets />
          </StackPane.margin>
         </ImageView>
      
          <!-- Left Branding Panel -->
          <VBox>
              <padding>
               <Insets bottom="40" left="48" right="48" top="40" />
            </padding>
      
              <Label styleClass="brand-logo" text="Seira" />
      
              <Region VBox.vgrow="ALWAYS" />
      
              <VBox spacing="16">
                  <Label styleClass="login-headline" text="Start your" />
                  <Label styleClass="login-headline" text="fiscal" />
                  <Label styleClass="login-headline-accent" text="journey." />
                  <Label styleClass="login-tagline" text="Create your personal ledger and take&#10;control of your financial narrative&#10;with Seira's intelligent tracking." wrapText="true" />
              </VBox>
      
              <Region VBox.vgrow="ALWAYS" />
      
              <Label styleClass="login-footer" text="ESTABLISHED MMXXIV © SEIRA FISCAL" />
          </VBox>
      </StackPane>

    <!-- Right Register Panel -->
    <VBox prefWidth="520" styleClass="login-right" HBox.hgrow="ALWAYS">
        <padding><Insets bottom="0" left="64" right="64" top="0" /></padding>
        <alignment>CENTER</alignment>

        <VBox maxWidth="360" spacing="8">
            <Label styleClass="login-title" text="Create Account" />
            <Label styleClass="login-subtitle" text="Set up your Seira account to start curating your wealth." wrapText="true" />
        </VBox>

        <Region prefHeight="32" />

        <VBox maxWidth="360" spacing="16">
            <VBox spacing="6">
                <Label styleClass="field-label" text="FULL NAME" />
                <TextField fx:id="usernameField" promptText="Your name" styleClass="login-field" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="EMAIL ADDRESS" />
                <TextField fx:id="emailField" promptText="curator@seira.com" styleClass="login-field" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="PASSWORD" />
                <PasswordField fx:id="passwordField" promptText="Min. 6 characters" styleClass="login-field" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="CONFIRM PASSWORD" />
                <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password" styleClass="login-field" />
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true" />
            <Label fx:id="successLabel" styleClass="success-label" visible="false" wrapText="true" />

            <Region prefHeight="4" />

            <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="btn-primary-full" text="Create Account" />

            <HBox alignment="CENTER" spacing="4">
                <Label styleClass="login-subtitle" text="Already have an account?" />
                <Label onMouseClicked="#goToLogin" styleClass="link-label" text="Log in" />
            </HBox>
        </VBox>
    </VBox>
</HBox>
